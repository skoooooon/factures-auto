# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env sur GitHub

# ── Pennylane ──────────────────────────────────────────────
PENNYLANE_EMAIL=depot-xxxxx@pennylane.com

# ── Gmail expéditeur (SMTP) ────────────────────────────────
SMTP_EMAIL=votre@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx   # Mot de passe d'application (16 car.)

# ── Total Energies ─────────────────────────────────────────
TOTAL_LOGIN=votre@email.com
TOTAL_PASSWORD=votre_mot_de_passe

# ── APRR ───────────────────────────────────────────────────
APRR_LOGIN=votre@email.com
APRR_PASSWORD=votre_mot_de_passe

# ── EasyJet ────────────────────────────────────────────────
EASYJET_LOGIN=votre@email.com
EASYJET_PASSWORD=votre_mot_de_passe
